# CodeAI-X — Compose environment variables
# Copy to `.env` in this same directory (docker/) and fill in real values.
# NEVER commit the real `.env` file. Add `docker/.env` to .gitignore.

# --- PostgreSQL ---
POSTGRES_DB=codeaix
POSTGRES_USER=codeaix_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM_VALUE

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_STRONG_RANDOM_VALUE

# --- Domain (used by nginx/certbot in the next phase) ---
DOMAIN_NAME=codeai-x.example.com
CERTBOT_EMAIL=admin@example.com
